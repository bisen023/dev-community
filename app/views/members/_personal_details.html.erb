<%= turbo_frame_tag :remote_modal, target: :_top do %>
  <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModal" aria-hidden="true" data-controller="bs-modal">
    <div class="modal-dialog">
      <div class="modal-content">
      
        <div class="modal-header">
          <h1 class="modal-title fs-5" id="exampleModal">Edit Personal Details</h1>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <%= form_with model: current_user, url: update_member_personal_details_path, method: :patch, data: { turbo_frame: "_top" } do |f| %>
          <div class="modal-body">
            <div class="row">
              <div class="col-lg-12">
                  <div class="form-group row">
                    <div class="col-lg-6">
                      <%= f.label :city, class:"mb-2" %>
                      <%= f.text_field :city, class:"form-control"%>
                    </div>
                    <div class="col-lg-6">
                      <%= f.label :state, class:"mb-2" %>
                      <%= f.text_field :state, class:"form-control"%>
                    </div>
                    <div class="col-lg-6">
                      <%= f.label :country, class:"mb-2" %>
                      <%= f.text_field :country, class:"form-control"%>
                    </div>
                    <div class="col-lg-6">
                      <%= f.label :pincode, class:"mb-2" %>
                      <%= f.text_field :pincode, class:"form-control"%>
                    </div>
                  </div>
 
          <div class="modal-footer">
            <%= f.submit "Save changes", class: "btn btn-primary", data: { action: "click->bs-modal#submitEnd" } %>
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
          </div>
        <% end %>

      </div>
    </div>
  </div>
<% end %>
